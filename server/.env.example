# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/subscription_db

# JWT
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:5173/payments/success
STRIPE_CANCEL_URL=http://localhost:5173/payments/cancel

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=invoices@yourdomain.com

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=./uploads

# Frontend URL
CLIENT_URL=http://localhost:5173
