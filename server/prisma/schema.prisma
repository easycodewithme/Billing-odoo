// Subscription Management System — PostgreSQL schema via Prisma.
// Json? on AuditLog maps to PostgreSQL jsonb (Prisma Json type).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// App login identity: staff (admin, internal_user) or customer (portal_user). Example: role = portal_user after signup.
enum Role {
  admin
  internal_user
  portal_user
}

/// How often the recurring plan price repeats. Example: monthly = bill every month.
enum BillingPeriod {
  daily
  weekly
  monthly
  yearly
}

/// Subscription sales/lifecycle. Example: draft → quotation → confirmed → active.
enum SubscriptionStatus {
  draft
  quotation
  confirmed
  active
  paused
  closed
}

/// Invoice billing state. Example: draft (generated) → confirmed (sent) → paid.
enum InvoiceStatus {
  draft
  confirmed
  paid
  cancelled
}

enum PaymentMethod {
  stripe
  cash
  bank_transfer
  other
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum DiscountType {
  fixed
  percentage
}

/// Audit log verb; use lowercase in code (create, update, delete).
enum AuditAction {
  create
  update
  delete
}

/// Staff and customers. FK targets: subscriptions.customerId, invoices.customerId, payments (via invoice), audit logs.
model User {
  id               String    @id @default(uuid())
  fullName         String
  email            String    @unique
  password         String
  phone            String?
  address          String?
  role             Role      @default(portal_user)
  avatar           String?
  isActive         Boolean   @default(true)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  subscriptions    Subscription[]
  invoices         Invoice[]
  statusChanges    SubscriptionStatusLog[] @relation("StatusChangedBy")
  auditLogs        AuditLog[]
  @@map("users")
}

/// Sellable item. Example: name "CRM Pro", salesPrice 99.99. Linked from order_lines, invoice_lines, template lines.
model Product {
  id          String   @id @default(uuid())
  name        String
  productType String?
  salesPrice  Decimal  @default(0)
  costPrice   Decimal  @default(0)
  description String?
  image       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants           ProductVariant[]
  orderLines         OrderLine[]
  invoiceLines       InvoiceLine[]
  quotationLines     QuotationTemplateLine[]
  discountProducts   DiscountProduct[]
  @@map("products")
}

/// Optional SKU-style row (e.g. Plan=Enterprise +50). FK productId → products.id (cascade delete).
model ProductVariant {
  id         String  @id @default(uuid())
  productId  String
  attribute  String
  value      String
  extraPrice Decimal @default(0)
  createdAt  DateTime @default(now())

  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderLines     OrderLine[]
  invoiceLines   InvoiceLine[]
  @@map("product_variants")
}

/// Billing cadence + base recurring price for a subscription. NOT “non-recurring”: one-time SKUs are still products; this table is “how often we bill this plan.” Example: Monthly Plan, price 99.99, billingPeriod monthly.
model RecurringPlan {
  id            String        @id @default(uuid())
  name          String
  price         Decimal
  billingPeriod BillingPeriod
  minQuantity   Int           @default(1)
  startDate     DateTime?
  endDate       DateTime?
  autoClose     Boolean       @default(false)
  closable      Boolean       @default(true)
  pausable      Boolean       @default(false)
  renewable     Boolean       @default(true)
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subscriptions      Subscription[]
  quotationTemplates QuotationTemplate[]

  @@map("recurring_plans")
}

/// One customer subscription: who (customerId), which billing plan (planId), workflow status. Child rows: order_lines (what to charge), invoices (bills), status_logs.
/// customerId → users.id: onDelete SetNull conflicts with required String in app terms—deleting a user can break NOT NULL in PostgreSQL; prefer not deleting users with live subscriptions.
model Subscription {
  id              String             @id @default(uuid())
  subscriptionNo  String             @unique
  /// FK → users.id (the paying customer; usually portal_user). Example UUID of John Doe.
  customerId      String
  /// FK → recurring_plans.id. Example: “Monthly Plan” row.
  planId          String
  startDate       DateTime?
  expirationDate  DateTime?
  paymentTerms    String?
  status          SubscriptionStatus @default(draft)
  salespersonId   String?
  quotationDate   DateTime?
  parentId        String?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  customer              User                    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  plan                  RecurringPlan           @relation(fields: [planId], references: [id])
  parent                Subscription?           @relation("SubscriptionHistory", fields: [parentId], references: [id])
  children              Subscription[]          @relation("SubscriptionHistory")
  orderLines            OrderLine[]
  invoices              Invoice[]
  statusLogs            SubscriptionStatusLog[]
  discountSubscriptions DiscountSubscription[]

  @@map("subscriptions")
}

/// Line item ON a subscription (cart before invoice). FK subscriptionId → subscriptions.id (cascade: delete sub deletes lines). FK productId → products.id. Used when generating invoice_lines (copy/snapshot).
model OrderLine {
  id             String  @id @default(uuid())
  /// Parent subscription this line belongs to. Example: sub id for SUB-173...
  subscriptionId String
  /// FK → products.id. Example: CRM Pro product.
  productId      String
  /// FK → product_variants.id (optional). Example: Enterprise variant.
  variantId      String?
  quantity       Int     @default(1)
  unitPrice      Decimal
  /// FK → taxes.id (optional). Example: GST 18%.
  taxId          String?
  /// FK → discounts.id (optional). Example: Launch 10%.
  discountId     String?
  amount         Decimal
  createdAt      DateTime @default(now())

  subscription Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product      Product         @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  tax          Tax?            @relation(fields: [taxId], references: [id], onDelete: SetNull)
  discount     Discount?       @relation(fields: [discountId], references: [id], onDelete: SetNull)

  @@map("order_lines")
}

/// Named preset of products + default plan (speeds creating subscriptions). FK recurringPlanId → recurring_plans.id.
model QuotationTemplate {
  id              String @id @default(uuid())
  name            String
  validityDays    Int    @default(30)
  recurringPlanId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recurringPlan RecurringPlan           @relation(fields: [recurringPlanId], references: [id])
  templateLines QuotationTemplateLine[]

  @@map("quotation_templates")
}

/// One row in a template “basket.” FK templateId → quotation_templates.id (cascade). FK productId → products.id.
model QuotationTemplateLine {
  id         String  @id @default(uuid())
  templateId String
  productId  String
  quantity   Int     @default(1)
  unitPrice  Decimal

  template QuotationTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  product  Product           @relation(fields: [productId], references: [id])

  @@map("quotation_template_lines")
}

/// Bill for a subscription. FK subscriptionId → subscriptions.id, customerId → users.id (denormalized for queries).
model Invoice {
  id               String        @id @default(uuid())
  invoiceNo        String        @unique
  subscriptionId   String
  customerId       String
  issuedAt         DateTime?
  dueDate          DateTime?
  status           InvoiceStatus @default(draft)
  totalAmount      Decimal       @default(0)
  taxAmount        Decimal       @default(0)
  discountAmount   Decimal       @default(0)
  netAmount        Decimal       @default(0)
  paidAmount       Decimal       @default(0)
  outstandingAmount Decimal      @default(0)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  customer     User         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  invoiceLines InvoiceLine[]
  payments     Payment[]

  @@map("invoices")
}

/// Line on an invoice (snapshot from order lines at generation time). FK invoiceId → invoices.id (cascade).
model InvoiceLine {
  id             String  @id @default(uuid())
  invoiceId      String
  productId      String
  variantId      String?
  description    String?
  quantity       Int     @default(1)
  unitPrice      Decimal
  taxId          String?
  taxAmount      Decimal @default(0)
  discountAmount Decimal @default(0)
  amount         Decimal
  createdAt      DateTime @default(now())

  invoice Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  tax     Tax?            @relation(fields: [taxId], references: [id], onDelete: SetNull)

  @@map("invoice_lines")
}

/// Money applied to an invoice. FK invoiceId → invoices.id.
model Payment {
  id                    String        @id @default(uuid())
  invoiceId             String
  method                PaymentMethod
  amount                Decimal
  paymentDate           DateTime      @default(now())
  stripeSessionId       String?
  stripePaymentIntentId String?
  status                PaymentStatus @default(pending)
  reference             String?
  notes                 String?
  createdAt             DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("payments")
}

/// Tax rate for lines. FK from order_lines.tax_id, invoice_lines.tax_id.
model Tax {
  id          String  @id @default(uuid())
  name        String
  rate        Decimal
  type        String
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderLines   OrderLine[]
  invoiceLines InvoiceLine[]

  @@map("taxes")
}

/// Discount rule. FK from order_lines.discount_id; also M2M via discount_products / discount_subscriptions.
model Discount {
  id           String       @id @default(uuid())
  name         String
  type         DiscountType
  value        Decimal
  minPurchase  Decimal      @default(0)
  minQuantity  Int          @default(0)
  startDate    DateTime
  endDate      DateTime
  limitUsage   Int?
  currentUsage Int          @default(0)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orderLines            OrderLine[]
  discountProducts      DiscountProduct[]
  discountSubscriptions DiscountSubscription[]

  @@map("discounts")
}

/// M2M: which products a discount can apply to. Composite PK (discountId, productId).
model DiscountProduct {
  discountId String
  productId  String

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([discountId, productId])
  @@map("discount_products")
}

/// M2M: discount scoped to specific subscriptions (eligibility metadata).
model DiscountSubscription {
  discountId     String
  subscriptionId String

  discount     Discount     @relation(fields: [discountId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@id([discountId, subscriptionId])
  @@map("discount_subscriptions")
}

/// Append-only history when subscription.status changes. FK subscriptionId → subscriptions.id; changedById → users.id (nullable).
model SubscriptionStatusLog {
  id             String   @id @default(uuid())
  subscriptionId String
  fromStatus     String
  toStatus       String
  changedById    String?
  reason         String?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  changedBy    User?        @relation("StatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@map("subscription_status_logs")
}

/// Generic change log. oldValues/newValues are JSON (PostgreSQL jsonb). Example: { "status": "draft" }.
model AuditLog {
  id        String      @id @default(uuid())
  tableName String
  recordId  String
  action    AuditAction
  oldValues Json?
  newValues Json?
  userId    String?
  createdAt DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

